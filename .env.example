# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@localhost:5432/cora
CORA_SCORER_MODE=nemo

# ── Gemma 3n E4B (Tier 0 — NVIDIA) ──────────────────────────────────────────
NVIDIA_GEMMA_API_KEY=your-nvidia-api-key

# ── Mistral Nemotron (Tier 1 — NVIDIA) ──────────────────────────────────────
NVIDIA_NEMOTRON_API_KEY=your-nvidia-api-key

# ── Magistral Small 2506 (Tier 2 — NVIDIA) ──────────────────────────────────
NVIDIA_MAGISTRAL_API_KEY=your-nvidia-api-key

# ── Mistral Medium 3 (Tier 3 — NVIDIA) ──────────────────────────────────────
NVIDIA_MISTRAL_MEDIUM_API_KEY=your-nvidia-api-key

# ── Mistral Large 3 675B (Tier 4 — NVIDIA) ───────────────────────────────────
NVIDIA_MISTRAL_LARGE_API_KEY=your-nvidia-api-key

# ── Devstral 2 123B (Prompt Optimizer — NVIDIA) ─────────────────────────────
NVIDIA_DEVSTRAL_API_KEY=your-nvidia-api-key
