# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@localhost:5432/cora
CORA_SCORER_MODE=nemo

# ── Nemotron Mini 4B (Tier 0 — NVIDIA) ──────────────────────────────────────
NVIDIA_NEMOTRON_MINI_API_KEY=your-nvidia-api-key

# ── Solar 10.7B (Tier 0 Fallback — NVIDIA) ──────────────────────────────────
NVIDIA_SOLAR_API_KEY=your-nvidia-api-key

# ── Nemotron Nano 30B Reasoning (Tier 1 — NVIDIA) ───────────────────────────
NVIDIA_NEMOTRON_NANO_API_KEY=your-nvidia-api-key

# ── Mistral Nemotron (Tier 2 — NVIDIA) ──────────────────────────────────────
NVIDIA_NEMOTRON_API_KEY=your-nvidia-api-key

# ── Step 3.5 Flash (Tier 2 Fallback — NVIDIA) ───────────────────────────────
NVIDIA_STEP_FLASH_API_KEY=your-nvidia-api-key

# ── Mistral Large 3 675B (Tier 3 — NVIDIA) ──────────────────────────────────
NVIDIA_MISTRAL_LARGE_API_KEY=your-nvidia-api-key

# ── MiniMax M2.7 (Tier 3 Fallback — NVIDIA) ─────────────────────────────────
NVIDIA_MINIMAX_API_KEY=your-nvidia-api-key

# ── Qwen3 Coder 480B (Tier 4 — NVIDIA) ──────────────────────────────────────
NVIDIA_QWEN3_CODER_API_KEY=your-nvidia-api-key

# ── Prompt Optimizer (Mistral Nemotron — NVIDIA) ──────────────────────────────
NVIDIA_PROMPT_OPTIMIZER_API_KEY=your-nvidia-api-key
